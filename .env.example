# LoreKeeper Environment Variables

# Gemini API Key (optional, nur wenn llm.provider = gemini)
GEMINI_API_KEY=

# ChromaDB Modus Override (embedded = lokal, client = Docker)
# CHROMA_MODE=embedded

# LLM Provider Override
# LLM__PROVIDER=ollama
# LLM__OLLAMA__BASE_URL=http://localhost:11434
# LLM__OLLAMA__MODEL=qwen3:8b
